{
  "name": "spindle-demo-minimal",
  "private": true,
  "version": "1.0.0",
  "description": "Versao enxuta do Spindle para demo e treinamento",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w apps/frontend",
    "dev:backend": "npm run dev -w apps/backend",
    "dev": "concurrently -k -n frontend,backend -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "npm run build -w apps/frontend",
    "build": "npm run build:frontend",
    "start:backend": "npm run start -w apps/backend",
    "start": "npm run start:backend",
    "lint:frontend": "npm run lint -w apps/frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
